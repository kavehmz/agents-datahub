FROM golang:1.25-alpine AS builder

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build the hub binary
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/bin/hub ./hub

# Final stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates && \
    addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /app

# Copy binary
COPY --from=builder /app/bin/hub /app/hub

# Copy default config
COPY config/hub-config.yaml /app/config.yaml

RUN chown -R appuser:appgroup /app

USER appuser

EXPOSE 50051 8080 9090

CMD ["/app/hub", "-config", "/app/config.yaml"]